# ==============================================
# ICS SANITAIRE - Environment Variables
# ==============================================

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# n8n Webhooks Configuration
N8N_BASE_URL=https://your-n8n-instance.railway.app
N8N_WEBHOOK_SECRET=your-secure-webhook-secret-min-32-chars
NEXT_PUBLIC_N8N_QUOTE_PDF_WEBHOOK=https://your-n8n-instance.railway.app/webhook/quote-pdf
NEXT_PUBLIC_N8N_REPORT_PDF_WEBHOOK=https://your-n8n-instance.railway.app/webhook/report-pdf
NEXT_PUBLIC_N8N_CONFIRMATION_REGIE_WEBHOOK=https://your-n8n-instance.railway.app/webhook/confirmation-regie

# External API Keys (for n8n workflows)
# OPENAI_API_KEY=your-openai-key
# PDFMONKEY_API_KEY=your-pdfmonkey-key
# TAYO_API_KEY=your-tayo-key
# TAYO_API_URL=https://api.tayo.ch/v1

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ICS Sanitaire

# Web Push (VAPID keys - generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
